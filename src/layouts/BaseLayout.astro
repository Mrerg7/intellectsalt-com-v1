---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  publishedDate?: Date;
}

const {
  title,
  description,
  image = 'https://imagedelivery.net/-sPAUAWeA405NiWJ0SNIQA/14c447b1-fc32-41d5-a132-d9ce1f610e00/public',
  canonicalURL = 'https://intellectsalt.com/',
  publishedDate = new Date(),
} = Astro.props;

const siteName = 'intellectsalt.com';
const siteURL = 'https://intellectsalt.com';
const ogImage = image;
const currentYear = new Date().getFullYear();
const dateFormatted = publishedDate.toISOString().split('T')[0];
const dateDisplay = publishedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'intellectsalt.com — Premium Brandable Domain',
  description: description,
  image: ogImage,
  url: siteURL,
  brand: {
    '@type': 'Brand',
    name: 'intellectsalt.com',
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: siteURL,
    seller: {
      '@type': 'Organization',
      name: 'intellectsalt.com',
      email: 'sales@desertrich.com',
    },
  },
  category: 'Domain Name',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="google-site-verification" content="NaZlE55e_wvRJdpOMELh3MjAdrkl98ZhWYzCd6hsb20" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="intellectsalt.com — The Essential Seasoning of the Mind" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="intellectsalt.com — The Essential Seasoning of the Mind" />

    <!-- Structured Data: JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}>
    </script>

    <!-- Favicon (Cloudflare Images CDN) -->
    <link rel="icon" type="image/png" sizes="32x32" href="https://imagedelivery.net/-sPAUAWeA405NiWJ0SNIQA/14c447b1-fc32-41d5-a132-d9ce1f610e00/w=32,h=32,fit=crop" />
    <link rel="icon" type="image/png" sizes="16x16" href="https://imagedelivery.net/-sPAUAWeA405NiWJ0SNIQA/14c447b1-fc32-41d5-a132-d9ce1f610e00/w=16,h=16,fit=crop" />
    <link rel="apple-touch-icon" sizes="180x180" href="https://imagedelivery.net/-sPAUAWeA405NiWJ0SNIQA/14c447b1-fc32-41d5-a132-d9ce1f610e00/w=180,h=180,fit=crop" />

    <!-- Preconnect to Cloudflare Images -->
    <link rel="preconnect" href="https://imagedelivery.net" />
    <link rel="dns-prefetch" href="https://imagedelivery.net" />
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <header class="w-full border-b border-brand-800/50">
      <nav class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
        <a href="/" class="text-brand-100 font-serif text-xl font-bold tracking-tight hover:text-brand-50 transition-colors">
          intellectsalt<span class="text-accent">.</span>com
        </a>
        <a
          href="mailto:sales@desertrich.com"
          class="text-sm text-brand-400 hover:text-accent-light transition-colors font-medium"
        >
          Inquire →
        </a>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="w-full border-t border-brand-800/50 mt-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- CTA Section -->
        <div class="section-card text-center mb-10">
          <h2 class="text-2xl md:text-3xl font-serif font-bold text-brand-50 mb-3">
            Secure This Domain Asset
          </h2>
          <p class="text-brand-400 mb-6 max-w-2xl mx-auto">
            <strong>intellectsalt.com</strong> is available for acquisition by serious buyers and organizations
            seeking a distinctive, high-potential digital property. Pricing available upon request.
          </p>
          <a
            href="mailto:sales@desertrich.com?subject=intellectsalt.com%20Acquisition%20Inquiry"
            class="cta-button text-lg"
          >
            Contact: sales@desertrich.com
          </a>
        </div>

        <!-- Disclaimer -->
        <div class="text-center text-brand-500 text-xs leading-relaxed max-w-3xl mx-auto space-y-1">
          <p>
            This website is for demonstration and informational purposes only.
            It does not constitute an offer of services, a commitment to deploy,
            or a guarantee of outcomes.
          </p>
          <p>
            All statistics, projections, and references to specific technologies
            are based on publicly available information as of {dateDisplay} and are subject to change.
          </p>
          <p class="mt-3 text-brand-600">
            &copy; {currentYear} intellectsalt.com. All rights reserved.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
